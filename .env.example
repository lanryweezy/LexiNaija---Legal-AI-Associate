# ===========================================
# LEXINAIJA ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# SUPABASE (Required)
# ===========================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# AI SERVICES (Required for AI features)
# ===========================================
# Server-side only - never exposed to client
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# ===========================================
# PAYMENTS (Optional)
# ===========================================
# Get from your Paystack dashboard
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-key

# ===========================================
# ERROR TRACKING (Optional)
# ===========================================
# Get from your Sentry dashboard
VITE_SENTRY_DSN=https://your-sentry-dsn

# ===========================================
# APP VERSION (Optional)
# ===========================================
# Used for release tracking in Sentry
VITE_APP_VERSION=1.0.0

# ===========================================
# SECURITY NOTES
# ===========================================
# - API keys are now used server-side only (/api/ai)
# - Client only needs VITE_ prefixed variables
# - Server-side keys (GEMINI_API_KEY, GROQ_API_KEY) 
#   must be set in your hosting platform (Vercel)
# ===========================================
